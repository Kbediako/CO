      "truth_checks": [
        "codex-cli-version",
        "model-posture",
        "default-runtime"
      ]
    },
    {
      "path": "docs/TASKS.md",
      "status": "active",
      "tier": 2,
      "doc_class": "report_only",
      "audience": "maintainers and reviewers",
      "source_of_truth": [
        "tasks/tasks-*.md",
        "tasks/index.json",
