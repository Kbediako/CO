      "status": "active",
      "tier": 1,
      "doc_class": "shipped_companion",
      "audience": "downstream Codex users",
      "source_of_truth": [
        "docs/guides/codex-version-policy.md",
        "skills/delegation-usage/SKILL.md"
      ],
      "owner": "Codex (top-level agent), Review agent",
      "cadence_days": 30,
      "update_triggers": [
        "Codex compatibility posture changes",
        "delegation MCP behavior changes"
      ],
      "truth_checks": [
        "codex-cli-version",
        "model-posture"
      ]
    },
    {
      "path": "templates/codex/AGENTS.md",
      "status": "active",
      "tier": 1,
      "doc_class": "seeded_template",
      "audience": "downstream seeded repositories",
      "source_of_truth": [
        "AGENTS.md",
        "docs/guides/codex-version-policy.md"
      ],
      "owner": "Codex (top-level agent), Review agent",
      "cadence_days": 30,
      "update_triggers": [
        "Codex compatibility posture changes",
        "runtime posture changes",
        "seeded downstream policy changes"
