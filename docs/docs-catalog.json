  "patterns": [
    {
      "glob": "docs/PRD-*.md",
      "status": "active",
      "doc_class": "task_packet",
      "audience": "task-local maintainers and reviewers",
      "source_of_truth": [
        "Linear or task source issue",
        "tasks/specs/*.md"
      ],
      "owner": "Codex (top-level agent), Review agent",
      "cadence_days": 30,
      "update_triggers": [
        "task scope changes",
        "task acceptance changes"
      ]
    },
    {
      "glob": "docs/ACTION_PLAN-*.md",
      "status": "active",
      "doc_class": "task_packet",
      "audience": "task-local maintainers and reviewers",
      "source_of_truth": [
        "tasks/specs/*.md",
        "task implementation state"
      ],
      "owner": "Codex (top-level agent), Review agent",
      "cadence_days": 30,
      "update_triggers": [
        "task sequencing changes",
        "task validation changes"
      ]
    },
    {
      "glob": "docs/TECH_SPEC-*.md",
      "status": "active",
      "doc_class": "task_packet",
      "audience": "task-local maintainers and reviewers",
      "source_of_truth": [
        "tasks/specs/*.md"
      ],
      "owner": "Codex (top-level agent), Review agent",
      "cadence_days": 30,
      "update_triggers": [
        "task implementation changes",
        "validation contract changes"
      ]
    },
    {
      "glob": "docs/findings/**/*.md",
      "status": "active",
      "doc_class": "report_only",
      "audience": "maintainers and reviewers",
      "source_of_truth": [
        "task packets",
        "review findings"
      ],
      "owner": "Codex (top-level agent), Review agent",
      "cadence_days": 30,
      "update_triggers": [
        "deliberation or review updates"
      ]
    },
    {
      "glob": "docs/**/*.md",
      "status": "active",
      "doc_class": "active_guide",
      "audience": "contributors and maintainers",
      "source_of_truth": [
        "repo implementation",
        "README.md",
        "AGENTS.md"
      ],
      "owner": "Codex (top-level agent), Review agent",
      "cadence_days": 30,
      "update_triggers": [
        "command-surface changes",
        "policy changes",
        "workflow changes"
      ]
    },
    {
      "glob": "tasks/**/*.md",
      "status": "active",
      "doc_class": "task_packet",
      "audience": "task-local maintainers and reviewers",
      "source_of_truth": [
        "task issue",
        "implementation state"
      ],
      "owner": "Codex (top-level agent), Review agent",
      "cadence_days": 30,
      "update_triggers": [
        "task scope changes",
        "task validation changes"
      ]
    },
    {
      "glob": ".agent/task/*.md",
      "status": "active",
      "doc_class": "task_mirror",
      "audience": "agents and reviewers",
      "source_of_truth": [
        "tasks/tasks-*.md"
      ],
      "owner": "Codex (top-level agent), Review agent",
      "cadence_days": 30,
      "update_triggers": [
        "task checklist changes"
      ]
    },
    {
      "glob": ".agent/SOPs/**/*.md",
      "status": "active",
      "doc_class": "active_guide",
      "audience": "agents and maintainers",
      "source_of_truth": [
        "AGENTS.md",
        "repo workflow behavior"
      ],
      "owner": "Codex (top-level agent), Review agent",
      "cadence_days": 30,
      "update_triggers": [
        "workflow changes",
        "merge or review policy changes"
      ]
    },
    {
      "glob": ".agent/**/*.md",
      "status": "active",
      "doc_class": "agent_policy",
      "audience": "agents and maintainers",
      "source_of_truth": [
        "AGENTS.md",
        "repo workflow behavior"
      ],
      "owner": "Codex (top-level agent), Review agent",
      "cadence_days": 30,
      "update_triggers": [
        "agent workflow changes"
      ]
    },
    {
      "glob": ".ai-dev-tasks/**/*.md",
      "status": "active",
      "doc_class": "task_packet",
      "audience": "task-local maintainers and reviewers",
      "source_of_truth": [
        "task issue",
        "implementation state"
      ],
      "owner": "Codex (top-level agent), Review agent",
      "cadence_days": 30,
      "update_triggers": [
        "task scope changes"
      ]
    },
    {
      "glob": "skills/*/SKILL.md",
      "status": "active",
      "doc_class": "shipped_skill",
      "audience": "downstream Codex users",
      "source_of_truth": [
        "README.md",
        "repo behavior"
      ],
      "owner": "Codex (top-level agent), Review agent",
      "cadence_days": 30,
      "update_triggers": [
        "bundled skill contract changes",
        "command or workflow changes"
      ]
    },
    {
      "glob": "skills/**/*.md",
      "status": "active",
      "doc_class": "shipped_companion",
      "audience": "downstream Codex users",
      "source_of_truth": [
        "skills/*/SKILL.md",
        "repo behavior"
      ],
      "owner": "Codex (top-level agent), Review agent",
      "cadence_days": 30,
      "update_triggers": [
        "bundled skill contract changes",
        "workflow changes"
      ]
    },
    {
      "glob": "templates/**/*.md",
      "status": "active",
      "doc_class": "seeded_template",
      "audience": "downstream seeded repositories",
      "source_of_truth": [
        "AGENTS.md",
        "README.md",
        "repo behavior"
      ],
      "owner": "Codex (top-level agent), Review agent",
      "cadence_days": 30,
      "update_triggers": [
        "seeded template changes",
        "downstream policy changes"
      ]
    }
  ]
}
