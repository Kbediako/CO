    {
      "path": "docs/AGENTS.md",
      "status": "active",
      "tier": 1,
      "doc_class": "agent_policy",
      "audience": "repo agents and maintainers",
      "source_of_truth": [
        "AGENTS.md",
        "docs/guides/codex-version-policy.md"
      ],
      "owner": "Codex (top-level agent), Review agent",
      "cadence_days": 30,
      "update_triggers": [
        "Codex compatibility posture changes",
        "runtime posture changes",
        "docs gate changes"
      ],
      "truth_checks": [
        "codex-cli-version",
        "model-posture",
        "default-runtime"
      ]
    },
    {
      "path": "docs/guides/codex-version-policy.md",
      "status": "active",
      "tier": 1,
      "doc_class": "active_guide",
      "audience": "maintainers and reviewers",
      "source_of_truth": [
        "self"
      ],
      "owner": "Codex (top-level agent), Review agent",
