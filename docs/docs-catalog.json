{
  "version": 1,
  "classes": {
    "front_door": {
      "label": "Front Door",
      "report_order": 10
    },
    "repo_guide": {
      "label": "Repository Guide",
      "report_order": 20
    },
    "agent_policy": {
      "label": "Agent Policy",
      "report_order": 30
    },
    "active_guide": {
      "label": "Active Guide",
      "report_order": 40
    },
    "shipped_skill": {
      "label": "Shipped Skill",
      "report_order": 50
    },
    "shipped_companion": {
      "label": "Shipped Companion",
      "report_order": 60
    },
    "seeded_template": {
      "label": "Seeded Template",
      "report_order": 70
    },
    "task_packet": {
      "label": "Task Packet",
      "report_order": 200
    },
    "task_mirror": {
      "label": "Task Mirror",
      "report_order": 210
    },
    "report_only": {
      "label": "Report Only",
      "report_order": 220
    },
    "uncatalogued": {
      "label": "Uncatalogued",
      "report_order": 999
    }
  },
  "policies": {
    "codex_posture": {
      "source_path": "docs/guides/codex-version-policy.md"
    },
    "readme_front_door": {
      "path": "README.md",
      "max_lines": 240,
      "max_h2_sections": 9
    },
    "bundled_skills_roster": {
      "doc_path": "README.md",
      "section_heading": "## Skills (bundled)",
      "list_intro": "Bundled skills"
    }
  },
  "entries": [
    {
      "path": "README.md",
      "status": "active",
      "tier": 1,
      "doc_class": "front_door",
      "audience": "downstream users",
      "source_of_truth": [
        "docs/guides/codex-version-policy.md",
        "skills/*/SKILL.md",
        "docs/README.md"
      ],
      "owner": "Codex (top-level agent), Review agent",
      "cadence_days": 14,
      "update_triggers": [
        "Codex compatibility posture changes",
        "default runtime posture changes",
        "bundled skill roster changes",
        "front-door command-surface changes"
      ],
      "truth_checks": [
        "codex-cli-version",
        "model-posture",
        "default-runtime",
        "bundled-skills-roster",
        "front-door-budget"
      ]
    },
    {
      "path": "docs/README.md",
      "status": "active",
      "tier": 1,
      "doc_class": "repo_guide",
      "audience": "contributors and maintainers",
      "source_of_truth": [
        "README.md",
        "docs/guides/codex-version-policy.md",
        "skills/*/SKILL.md"
      ],
      "owner": "Codex (top-level agent), Review agent",
      "cadence_days": 30,
      "update_triggers": [
        "Codex compatibility posture changes",
        "repo command-surface changes",
        "bundled skill roster changes"
      ],
      "truth_checks": [
        "codex-cli-version",
        "model-posture",
        "default-runtime"
      ]
    },
    {
      "path": "AGENTS.md",
      "status": "active",
      "tier": 1,
      "doc_class": "agent_policy",
      "audience": "repo agents and maintainers",
      "source_of_truth": [
        "docs/guides/codex-version-policy.md",
        "templates/codex/AGENTS.md"
      ],
      "owner": "Codex (top-level agent), Review agent",
      "cadence_days": 30,
      "update_triggers": [
        "Codex compatibility posture changes",
        "runtime posture changes",
        "review policy changes"
      ],
      "truth_checks": [
        "codex-cli-version",
        "model-posture",
        "default-runtime"
      ]
